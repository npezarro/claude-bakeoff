#!/usr/bin/env bash
set -euo pipefail

ARENA_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
source "$ARENA_ROOT/bin/lib/common.sh"

usage() {
    cat <<'EOF'
claude-bakeoff — A/B testing for Claude across instruction recipes AND platforms

Usage:
  arena bake   <task> [--env-a NAME] [--env-b NAME] [--platform-a NAME] [--platform-b NAME]
  arena judge  <run-id>
  arena taste  <run-id>
  arena discord-report <run-id>
  arena merge  <run-id>
  arena list   [challenges|bakes|recipes|platforms]
  arena new    <task|recipe> <name>

Commands:
  bake             Put a challenge in the oven under both recipes
  judge            Send a completed bake to the judges
  taste            Display the judging results
  discord-report   Post results to #claude-bakeoff in Discord
  merge            Synthesize the best of both recipes into a merged response
  list             List challenges, past bakes, recipes, or platforms
  new              Prepare a new challenge or recipe

Options:
  --env-a NAME       Override recipe A (default: from config.yaml)
  --env-b NAME       Override recipe B (default: from config.yaml)
  --platform-a NAME  Override platform A (default: cli)
  --platform-b NAME  Override platform B (default: cli)
  --platforms A B    Set both platforms at once
  --id RUN_ID        Custom bake ID (default: timestamp-based)
  -h, --help         Show this help

Platforms:
  cli              Run via local `claude --print` CLI
  discord          Send to Discord bot channel, capture response

Examples:
  arena bake csv-parser
  arena bake csv-parser --env-a minimal --env-b verbose
  arena bake csv-parser --platform-a cli --platform-b discord
  arena bake csv-parser --platforms cli discord
  arena judge 20260319_143022
  arena list platforms
EOF
    exit 0
}

cmd="${1:-}"
shift || true

case "$cmd" in
    bake|run)       exec "$ARENA_ROOT/bin/run.sh" "$@" ;;
    judge|eval)     exec "$ARENA_ROOT/bin/evaluate.sh" "$@" ;;
    merge)          exec "$ARENA_ROOT/bin/merge.sh" "$@" ;;
    taste|report)   exec "$ARENA_ROOT/bin/report.sh" "$@" ;;
    discord-report) exec "$ARENA_ROOT/bin/discord-report.sh" "$@" ;;
    list)           exec "$ARENA_ROOT/bin/list.sh" "$@" ;;
    new)            exec "$ARENA_ROOT/bin/new.sh" "$@" ;;
    -h|--help|help|"") usage ;;
    *)      echo "Unknown command: $cmd" >&2; usage ;;
esac
