# Discord platform secrets — copy to ~/.config/claude-bakeoff/.env
# These are NOT read from the repo; they're sourced from the external path.

BAKEOFF_DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_ID/YOUR_TOKEN
BAKEOFF_DISCORD_CHANNEL=YOUR_CHANNEL_ID
BAKEOFF_DISCORD_BOT_ID=YOUR_BOT_USER_ID
